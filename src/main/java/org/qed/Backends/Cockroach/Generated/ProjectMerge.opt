[ProjectMerge, Normalize]
(Project
    $input:(Project
    $input_1:*
    $proj_2:*
    $innerPassthrough_3:*)
    $proj_0:* &
        (CanMergeProjections $proj_0 $proj_2)
    $passthrough_4:*
)
=>
(Project
    $input_1
    (MergeProjections
        $proj_0
        $proj_2
        $passthrough_4
    )
    (DifferenceCols
        $innerPassthrough_3
        (ProjectionCols $proj_2)
    )
)
