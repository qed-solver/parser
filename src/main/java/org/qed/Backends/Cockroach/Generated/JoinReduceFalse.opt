[JoinReduceFalse, Normalize]
(InnerJoin
    $input_0:*
    $input_1:*
    $on_2:[
        ...
        $item_3:(FiltersItem
            (And * (False))
        )
        ...
    ] &
        ^(IsFilterFalse $on_2)
    $private_4:*
)
=>
(InnerJoin
    $input_0
    $input_1
    [ (FiltersItem (False)) ]
