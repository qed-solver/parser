[JoinCommute, Normalize]
(InnerJoin
    $left_4:*
    $right_5:*
    $on_6:*
    $private_3:* &
        (CanCommuteJoin $left_4 $right_5)
)
=>
(Project
    (InnerJoin
        $right_5
        $left_4
        $on_6
        (CommuteJoinFlags $private_3)
    )
    (SwapJoinOutputColumns
        (OutputCols $left_4)
        (OutputCols $right_5)
    )
    (MakeEmptyColSet)
)
